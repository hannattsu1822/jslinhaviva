{
  "name": "jslinhaviva",
  "version": "1.0.0",
  "description": "Sistema de gestão de infraestrutura elétrica - Linhaviva",
  "main": "src/server.js",
  "scripts": {
    "start": "tsx src/server.js",
    "start:rele-tcp": "tsx src/gateways/rele_tcp_server.ts",
    "dev": "nodemon --exec tsx src/server.js",
    "typecheck:telemetry": "tsc -p tsconfig.telemetry.json",
    "typecheck:auth": "tsc -p tsconfig.auth.json",
    "typecheck:logbox": "tsc -p tsconfig.logbox.json",
    "typecheck:rele": "tsc -p tsconfig.rele.json",
    "typecheck": "npm run typecheck:telemetry && npm run typecheck:auth && npm run typecheck:logbox && npm run typecheck:rele",
    "start:cluster": "pm2 start src/server.js -i max --name jslinhaviva --interpreter tsx",
    "start:api": "node scripts/start-api-only.js",
    "export:fibra": "node scripts/export-fibra-pontos.js",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.js",
    "harden:frontend": "node scripts/harden-frontend-security.js && node scripts/fix-remaining-onclick.js"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "chartjs-node-canvas": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "mqtt": "^5.6.0",
    "multer": "^1.4.5-lts.2",
    "mysql2": "^3.14.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.16.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "playwright": "^1.61.0",
    "proj4": "^2.20.9",
    "tsx": "^4.19.4",
    "web-push": "^3.6.7",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.0.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
