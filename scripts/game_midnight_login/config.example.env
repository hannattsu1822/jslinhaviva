# Copie para config.env e preencha (não commite credenciais reais)

# Conta do Poketibia / OTClient
ACCOUNT=seu_login
PASSWORD=sua_senha

# Personagem: índice na lista (0 = primeiro, 1 = segundo...)
CHARACTER_INDEX=0

# Parte do título da janela do cliente (ex.: OTClient, Poketibia, nome do servidor)
WINDOW_TITLE_CONTAINS=OTClient

# Horário do Server Save (SS) — quando o servidor reinicia para salvar
SS_HOUR=0
SS_MINUTE=0
TIMEZONE=America/Sao_Paulo
PREWAKE_MINUTES=0

# Quanto esperar depois do SS para o servidor voltar (segundos)
SS_RESTART_WAIT_SEC=90

# Tentativas de relogin após o SS
LOGIN_RETRIES=15
LOGIN_RETRY_INTERVAL_SEC=30

# Modo de relogin:
#   full            — digita conta, senha, conecta e escolhe personagem
#   character_only  — só escolhe personagem (conta/senha já salvas no cliente)
#   enter_only      — só Enter (cliente já na tela de reconexão)
RELOGIN_MODE=full

# Pausa entre cada ação do teclado/mouse (segundos)
ACTION_DELAY_SEC=0.4
