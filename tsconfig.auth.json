{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "rootDir": "src",
    "baseUrl": "src"
  },
  "include": ["src/auth/**/*", "src/middleware/csrf.ts"],
  "exclude": ["node_modules"]
}
