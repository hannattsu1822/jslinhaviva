{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "rootDir": "src",
    "baseUrl": "src"
  },
  "include": [
    "src/modules/reles/**/*",
    "src/gateways/rele/**/*",
    "src/gateways/rele_tcp_server.ts",
    "src/auth/express.d.ts"
  ],
  "exclude": ["node_modules"]
}
