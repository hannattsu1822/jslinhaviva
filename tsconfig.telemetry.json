{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "rootDir": "src/telemetry",
    "baseUrl": "src/telemetry"
  },
  "include": ["src/telemetry/**/*"],
  "exclude": ["node_modules"]
}
